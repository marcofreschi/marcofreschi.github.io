---
import Base from '../layouts/Base.astro';
---
<Base title="Marco Freschi — Postdoctoral Researcher">
  <style>
    /* ── HERO ── */
    .hero {
      min-height: 100vh;
      display: grid;
      grid-template-columns: 1fr 1fr;
      position: relative;
    }

    .hero-left {
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
      padding: 0 4rem 5rem;
    }

    .hero-eyebrow {
      font-family: 'Consolas', 'Courier New', monospace;
      font-size: 0.7rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 1.5rem;
      display: flex;
      align-items: center;
      gap: 0.75rem;
      animation: fadeUp 0.8s ease both;
    }

    .hero-eyebrow::before {
      content: '';
      display: block;
      width: 2rem;
      height: 1px;
      background: var(--accent);
    }

    .hero-name {
      font-size: clamp(3.5rem, 7vw, 6.5rem);
      font-weight: 300;
      line-height: 1.0;
      letter-spacing: -0.02em;
      animation: fadeUp 0.8s 0.1s ease both;
    }

    .hero-name em {
      font-style: italic;
      color: var(--warm-mid);
    }

    .hero-tagline {
      margin-top: 2rem;
      font-size: 1.05rem;
      font-weight: 300;
      color: var(--warm-mid);
      max-width: 38ch;
      line-height: 1.6;
      animation: fadeUp 0.8s 0.2s ease both;
    }

    .hero-cta {
      margin-top: 3rem;
      display: flex;
      gap: 1.5rem;
      align-items: center;
      animation: fadeUp 0.8s 0.3s ease both;
    }

    .btn-primary {
      display: inline-flex;
      align-items: center;
      gap: 0.6rem;
      background: var(--ink);
      color: var(--paper);
      padding: 0.85rem 2rem;
      font-family: 'Consolas', 'Courier New', monospace;
      font-size: 0.7rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      transition: background 0.25s ease, transform 0.2s ease;
    }

    .btn-primary:hover {
      background: var(--accent);
      transform: translateY(-1px);
    }

    .btn-secondary {
      font-family: 'Consolas', 'Courier New', monospace;
      font-size: 0.7rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--warm-mid);
      border-bottom: 1px solid var(--accent-light);
      padding-bottom: 2px;
      transition: color 0.25s, border-color 0.25s;
    }

    .btn-secondary:hover { color: var(--ink); border-color: var(--accent); }

    /* ── HERO RIGHT ── */
    .hero-right {
      position: relative;
      overflow: hidden;
      background: var(--ink);
    }

    .hero-right::after {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(135deg, transparent 50%, rgba(193,127,58,0.15) 100%);
    }

    .hero-visual {
      position: absolute;
      inset: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      opacity: 0.08;
    }

    .hero-visual svg {
      width: 70%;
      height: auto;
    }

    .hero-label {
      position: absolute;
      bottom: 3rem;
      right: 3rem;
      text-align: right;
      z-index: 2;
      animation: fadeUp 0.8s 0.4s ease both;
    }

    .hero-label .institution {
      font-family: 'Georgia', 'Palatino Linotype', serif;
      font-size: 1.4rem;
      color: var(--paper);
      opacity: 0.9;
    }

    .hero-label .dept {
      font-family: 'Consolas', 'Courier New', monospace;
      font-size: 0.65rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--accent-light);
      margin-top: 0.35rem;
    }

    /* ── SCROLL INDICATOR ── */
    .scroll-hint {
      position: absolute;
      bottom: 2.5rem;
      left: 4rem;
      display: flex;
      align-items: center;
      gap: 0.75rem;
      font-family: 'Consolas', 'Courier New', monospace;
      font-size: 0.6rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--muted);
      animation: fadeIn 1s 1s ease both;
    }

    .scroll-line {
      width: 1px;
      height: 3rem;
      background: linear-gradient(to bottom, var(--accent), transparent);
      animation: lineGrow 1s 0.5s ease both;
    }

    /* ── ABOUT STRIP ── */
    .about-strip {
      display: grid;
      grid-template-columns: 1fr 2fr 1fr;
      gap: 0;
      border-top: 1px solid var(--line);
      border-bottom: 1px solid var(--line);
      margin: 0 4rem;
    }

    .about-cell {
      padding: 3rem 2.5rem;
      border-right: 1px solid var(--line);
    }

    .about-cell:last-child { border-right: none; }

    .about-cell .label {
      font-family: 'Consolas', 'Courier New', monospace;
      font-size: 0.65rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 1rem;
    }

    .about-cell .value {
      font-family: 'Georgia', 'Palatino Linotype', serif;
      font-size: 1.25rem;
      line-height: 1.4;
      font-weight: 300;
    }

    .about-cell p {
      font-size: 0.9rem;
      line-height: 1.7;
      color: var(--warm-mid);
    }

    /* ── RESEARCH ── */
    .research-section {
      padding: 7rem 4rem;
    }

    .section-header {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      margin-bottom: 4rem;
      border-bottom: 1px solid var(--line);
      padding-bottom: 1.5rem;
    }

    .section-title {
      font-size: clamp(2rem, 4vw, 3.5rem);
      font-weight: 300;
    }

    .section-link {
      font-family: 'Consolas', 'Courier New', monospace;
      font-size: 0.68rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--warm-mid);
      display: flex;
      align-items: center;
      gap: 0.5rem;
      transition: color 0.2s;
    }

    .section-link:hover { color: var(--accent); }

    .research-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 2px;
    }

    .research-card {
      background: white;
      padding: 2.5rem;
      position: relative;
      overflow: hidden;
      transition: transform 0.3s ease;
    }

    .research-card::before {
      content: '';
      position: absolute;
      bottom: 0; left: 0; right: 0;
      height: 2px;
      background: var(--accent);
      transform: scaleX(0);
      transition: transform 0.35s ease;
      transform-origin: left;
    }

    .research-card:hover { transform: translateY(-3px); }
    .research-card:hover::before { transform: scaleX(1); }

    .card-number {
      font-family: 'Consolas', 'Courier New', monospace;
      font-size: 0.65rem;
      letter-spacing: 0.1em;
      color: var(--accent);
      margin-bottom: 1.75rem;
    }

    .card-title {
      font-size: 1.35rem;
      font-weight: 400;
      margin-bottom: 1rem;
      line-height: 1.3;
    }

    .card-desc {
      font-size: 0.88rem;
      line-height: 1.65;
      color: var(--warm-mid);
    }

    .card-tag {
      display: inline-block;
      margin-top: 1.5rem;
      font-family: 'Consolas', 'Courier New', monospace;
      font-size: 0.6rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      background: var(--paper);
      color: var(--muted);
      padding: 0.3rem 0.75rem;
    }

    /* ── ANIMATIONS ── */
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(20px); }
      to { opacity: 1; transform: translateY(0); }
    }

    @keyframes fadeIn {
      from { opacity: 0; }
      to { opacity: 1; }
    }

    @keyframes lineGrow {
      from { transform: scaleY(0); transform-origin: top; }
      to { transform: scaleY(1); }
    }

    /* ── RESPONSIVE ── */
    @media (max-width: 900px) {
      .hero { grid-template-columns: 1fr; }
      .hero-right { min-height: 40vh; }
      .hero-left { padding: 7rem 1.5rem 3rem; }
      .about-strip { grid-template-columns: 1fr; margin: 0 1.5rem; }
      .about-cell { border-right: none; border-bottom: 1px solid var(--line); }
      .research-grid { grid-template-columns: 1fr; }
      .research-section { padding: 4rem 1.5rem; }
      .section-header { flex-direction: column; gap: 1rem; }
      .scroll-hint { display: none; }
    }
  </style>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-left">
      <p class="hero-eyebrow">Postdoctoral Researcher</p>
      <h1 class="hero-name">Marco<br /><em>Freschi</em></h1>
      <p class="hero-tagline">
        Designing materials that move, adapt, and respond — exploring bioinspired morphing systems at the frontier of sustainability and engineering.
      </p>
      <div class="hero-cta">
        <a href="/research" class="btn-primary">Explore Research →</a>
        <a href="/publications" class="btn-secondary">Publications</a>
      </div>
    </div>

    <div class="hero-right">
      <!-- Abstract geometric visual inspired by morphing materials -->
      <div class="hero-visual">
        <svg viewBox="0 0 400 400" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="200" cy="200" r="180" stroke="white" stroke-width="0.5"/>
          <circle cx="200" cy="200" r="120" stroke="white" stroke-width="0.5"/>
          <circle cx="200" cy="200" r="60" stroke="white" stroke-width="0.5"/>
          <path d="M 200 20 Q 380 200 200 380 Q 20 200 200 20" stroke="white" stroke-width="0.5"/>
          <path d="M 20 200 Q 200 380 380 200 Q 200 20 20 200" stroke="white" stroke-width="0.5"/>
          <line x1="20" y1="200" x2="380" y2="200" stroke="white" stroke-width="0.3"/>
          <line x1="200" y1="20" x2="200" y2="380" stroke="white" stroke-width="0.3"/>
          <line x1="60" y1="60" x2="340" y2="340" stroke="white" stroke-width="0.3"/>
          <line x1="340" y1="60" x2="60" y2="340" stroke="white" stroke-width="0.3"/>
        </svg>
      </div>
      <div class="hero-label">
        <p class="institution">UC Berkeley</p>
        <p class="dept">Morphing Materials Lab · Dept. ME</p>
      </div>
    </div>

    <div class="scroll-hint">
      <div class="scroll-line"></div>
      <span>Scroll</span>
    </div>
  </section>

  <!-- ABOUT STRIP -->
  <div class="about-strip">
    <div class="about-cell">
      <p class="label">Affiliation</p>
      <p class="value">Morphing Materials Lab<br />UC Berkeley</p>
    </div>
    <div class="about-cell">
      <p class="label">Focus</p>
      <p>
        My research bridges materials science and bioinspired design — from metal matrix composites and tribological systems to soft, stimuli-responsive structures that transform the way we think about seeding, growth, and sustainability.
      </p>
    </div>
    <div class="about-cell">
      <p class="label">Funding</p>
      <p class="value">PPFP Fellowship<br />NSF TTP-T Grant</p>
    </div>
  </div>

  <!-- RESEARCH PREVIEW -->
  <section class="research-section">
    <div class="section-header">
      <h2 class="section-title">Research Areas</h2>
      <a href="/research" class="section-link">All Projects →</a>
    </div>

    <div class="research-grid">
      <div class="research-card">
        <p class="card-number">01</p>
        <h3 class="card-title">Bioinspired Seeding Systems</h3>
        <p class="card-desc">Morphing structures that mimic plant seed dispersal mechanisms for sustainable and targeted reforestation applications.</p>
        <span class="card-tag">Active · NSF TTP-T</span>
      </div>
      <div class="research-card">
        <p class="card-number">02</p>
        <h3 class="card-title">Stimuli-Responsive Materials</h3>
        <p class="card-desc">4D-printed composites that respond to moisture, heat, and light — enabling programmable shape change without electronics.</p>
        <span class="card-tag">Active</span>
      </div>
      <div class="research-card">
        <p class="card-number">03</p>
        <h3 class="card-title">Metal Matrix Composites</h3>
        <p class="card-desc">Tribological behavior and mechanical performance of advanced MMCs — foundational work from Politecnico di Milano.</p>
        <span class="card-tag">PhD Research</span>
      </div>
    </div>
  </section>
</Base>
